# Reactific API — Environment Variables
# Render → Environment Tab
# Do not commit real secrets

# ─────────────────────────────────────
# ENVIRONMENT
# ─────────────────────────────────────

NODE_ENV=production

PORT=3001

# ─────────────────────────────────────
# SECURITY
# ─────────────────────────────────────

JWT_SECRET=

# Allowed browser origins
ALLOWED_ORIGINS=https://reactificgaming.com,https://www.reactificgaming.com

# ─────────────────────────────────────
# DATABASE
# ─────────────────────────────────────

DATABASE_URL=

# ─────────────────────────────────────
# STRIPE
# ─────────────────────────────────────

STRIPE_SECRET_KEY=sk_live_...

STRIPE_WEBHOOK_SECRET=whsec_...

STRIPE_PRICE_ID=price_...

# Return after successful subscribe
COMPETE_URL=https://reactificgaming.com/compete/strobe-01-compete.html

# Return after cancel
STRIPE_CANCEL_URL=https://reactificgaming.com/compete/com-01.html

# ─────────────────────────────────────
# FRONTEND
# ─────────────────────────────────────

CLIENT_URL=https://reactificgaming.com

API_URL=https://api.reactificgaming.com

# ─────────────────────────────────────
# COMPETITION
# ─────────────────────────────────────

COMPETE_ENABLED=true

LEADERBOARD_ENABLED=true

DAILY_CHALLENGE_ENABLED=true

SCHOOL_COMPETITION_ENABLED=true

# ─────────────────────────────────────
# DEFAULT CHALLENGE
# ─────────────────────────────────────

DEFAULT_CHALLENGE_CODE=daily

DEFAULT_CHALLENGE_NAME=Daily Challenge

DEFAULT_COURT=full

DEFAULT_SPEED=med

# ─────────────────────────────────────
# PLAYER HEADER
# Competition Header Identity
# (frontend uses stored values)
# ─────────────────────────────────────

PLAYER_DISPLAY_NAME=

PLAYER_SCHOOL_ORG=
